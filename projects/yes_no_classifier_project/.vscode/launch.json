{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Train Binary Classifier",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/train_binary_classifier.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "--data-root",
        "F:/data/newdata",
        "--epochs",
        "80",
        "--max-retries",
        "3",
        "--target-acc",
        "0.90"
      ]
    }
  ]
}
